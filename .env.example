# CBRS portal defaults
CBRS_PORTAL_BASE_URL=https://nuevo-portal.conservador.cl
CBRS_RECAPTCHA_SITEKEY=6Le-eiksAAAAANU-0ITcjxvGfFoHsz40juvUVI_-

# Local state. Keep these paths outside commits.
CBRS_DATA_DIR=V:\scrapper\scrapper-portal-conservador\data
CBRS_DATABASE_URL=sqlite:///V:/scrapper/scrapper-portal-conservador/data/cbrs.sqlite3
CBRS_BROWSER_PROFILE_DIR=V:\scrapper\scrapper-portal-conservador\.local\browser-profile

# Runtime behavior
CBRS_HEADLESS=false
CBRS_MIN_REQUEST_DELAY_MS=30000
CBRS_REQUEST_JITTER_PERCENT=20
CBRS_TRANSIENT_BACKOFF_MS=120000,300000,600000
CBRS_MAX_JOB_ATTEMPTS=3

# Deprecated compatibility knobs. The current live safety model has no successful-request cap.
# CBRS_DAILY_QUERY_BUDGET_PER_ACCOUNT=0
# CBRS_MAX_LIVE_REQUESTS_PER_RUN=12
# CBRS_MAX_WAF_FAILURES_PER_RUN=0
# CBRS_MAX_CAPTCHA_FAILURES_PER_RUN=0
# CBRS_MAX_AUTH_FAILURES_PER_RUN=1
# CBRS_MAX_TRANSIENT_FAILURES_PER_RUN=2

# Optional credentials. Prefer manual login with `cbrs init` when possible.
# Never commit real values.
CBRS_USER_1=
CBRS_PASSWORD_1=
# CBRS_USER_2=
# CBRS_PASSWORD_2=

# Optional experimental HTTP-only solver key. Not used by default.
CAPSOLVER_API_KEY=
